<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="approval_category_view_form_inherit_documents" model="ir.ui.view">
        <field name="name">approval.category.view.form.inherit.documents</field>
        <field name="model">approval.category</field>
        <field name="inherit_id" ref="approvals.approval_category_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='option_settings']" position="inside">
                <field name="type_degree" string="Type Degree" widget="radio" options="{'horizontal': true}"/>
            </xpath>
        </field>
    </record>
</odoo>
